# TrafficVision binds to localhost and stores all footage locally by default.
TV_HOST=127.0.0.1
TV_PORT=8000
TV_FRONTEND_URL=http://127.0.0.1:5173
TV_YOLO_MODEL=yolo11n.pt
TV_PERFORMANCE_PROFILE=CPU Light
TV_FRAME_SKIP=2
TV_INFERENCE_SIZE=640
TV_DETECTION_CONFIDENCE=0.35
TV_OCR_CONFIDENCE=0.65
TV_PLATE_DETECTOR_CONFIDENCE=0.40
TV_PLATE_OCR_ENABLED=false
TV_PRIVACY_ACKNOWLEDGED=false
TV_RETENTION_DAYS=30
TV_DEMO_MODE=false

